# Copy to .env and fill in values, then: source .env && uvicorn ytdlfin.main:app --reload

DATA_DIR=/tmp/ytdlfin-dev
SECRET_KEY=change-me-to-32-or-more-random-characters

OIDC_ISSUER_URL=https://id.example.com
OIDC_CLIENT_ID=ytdlfin
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# PocketID group names for access control (must match group names in PocketID exactly)
ADMIN_GROUP=ytdlfin-admins
USER_GROUP=ytdlfin-users

# Optional
# STAGING_DIR=/tmp/ytdlfin-dev/staging
# PORT=8000
# LOG_LEVEL=info
